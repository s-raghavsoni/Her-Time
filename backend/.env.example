NODE_ENV=development
PORT=5000

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/her_time

# Comma-separated allowed origins (Vite dev server by default)
CORS_ORIGIN=http://localhost:5173

# Secret for signing JWTs (required in production)
JWT_SECRET=change-me-in-production

# Production: set NODE_ENV=production and ensure DATABASE_URL is set
